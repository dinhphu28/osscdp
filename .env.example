# Copy to .env and adjust. Loaded by Docker Compose and the apps.

# PostgreSQL connection string used by cdp-api / cdp-worker / migrate.
DATABASE_URL=postgres://cdp:cdp@localhost:5432/cdp?sslmode=disable

# Static bearer token guarding the /admin API. Full RBAC arrives in Phase 9.
ADMIN_API_TOKEN=dev-admin-token-change-me

# HTTP listen address for cdp-api.
HTTP_ADDR=:8080

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --- Used by docker-compose only ---
POSTGRES_USER=cdp
POSTGRES_PASSWORD=cdp
POSTGRES_DB=cdp
# Host port for the dev Postgres (change if 5432 is already taken locally).
POSTGRES_PORT=5432
