# Copy to .env and adjust. Loaded by Docker Compose and the apps.

# PostgreSQL connection string used by cdp-api / cdp-worker / migrate.
DATABASE_URL=postgres://cdp:cdp@localhost:5432/cdp?sslmode=disable

# Static bearer token guarding the /admin API. Full RBAC arrives in Phase 9.
ADMIN_API_TOKEN=dev-admin-token-change-me

# HTTP listen address for cdp-api.
HTTP_ADDR=:8080

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --- Event pipeline (cdp-worker) ---
# Comma-separated Kafka/Redpanda seed brokers.
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=cdp-worker
# Prometheus metrics endpoint for cdp-worker.
METRICS_ADDR=:9100
# Outbox relay drain cadence and batch size.
RELAY_POLL_INTERVAL=1s
RELAY_BATCH_SIZE=100
# Per-message processing retries before dead-lettering.
MAX_RETRIES=5
# Activation sender loop cadence and batch size.
ACTIVATION_POLL_INTERVAL=2s
ACTIVATION_BATCH_SIZE=50

# --- Used by docker-compose only ---
POSTGRES_USER=cdp
POSTGRES_PASSWORD=cdp
POSTGRES_DB=cdp
# Host port for the dev Postgres (change if 5432 is already taken locally).
POSTGRES_PORT=5432
